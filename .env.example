# 小满人生档案馆 APP - Environment Example
# Copy this file to .env for local development.
# Never commit real .env files or production secrets.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
ADMIN_BOOTSTRAP_ENABLED=true

# -----------------------------------------------------------------------------
# Database - MySQL 8.x + Prisma
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://xiaoman:password@localhost:3307/xiaoman_archive

# -----------------------------------------------------------------------------
# Redis / Queue
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Auth - JWT
# Replace secrets before any shared testing or production deployment.
# Placeholder secrets are allowed for local development only.
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Object Storage
# local: minio
# production examples: oss / cos / s3 / r2
# local/test may use explicit mock; strict environments must use a non-mock provider
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
STORAGE_REGION=local
STORAGE_BUCKET=xiaoman-archive-local
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/xiaoman-archive-local
STORAGE_SIGNED_URL_EXPIRES_IN=600

# -----------------------------------------------------------------------------
# Upload Limits
# -----------------------------------------------------------------------------
UPLOAD_IMAGE_MAX_BYTES=10485760
UPLOAD_VIDEO_MAX_BYTES=104857600
UPLOAD_AUDIO_MAX_BYTES=31457280
UPLOAD_IMAGE_MAX_COUNT_PER_RECORD=9
UPLOAD_VIDEO_MAX_COUNT_PER_RECORD=1
UPLOAD_AUDIO_MAX_COUNT_PER_RECORD=1

# -----------------------------------------------------------------------------
# AI Provider
# local/test can use explicit mock. strict environments must not use mock.
# -----------------------------------------------------------------------------
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_MS=30000
AI_MAX_RETRY_COUNT=2
AI_DAILY_LIMIT_PER_USER=20

# -----------------------------------------------------------------------------
# SMS Provider
# local/test can use explicit mock verification codes.
# strict environments must use a real provider and cannot silently fall back.
# -----------------------------------------------------------------------------
SMS_PROVIDER=mock
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_ENDPOINT=https://dysmsapi.aliyuncs.com
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_MOCK_CODE=123456
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT_PER_MOBILE=10
SMS_VERIFY_MAX_ATTEMPTS=5
SMS_CODE_PEPPER=replace_me_sms_pepper

# -----------------------------------------------------------------------------
# Admin Bootstrap
# Local development may use bootstrap admin creation.
# Shared test / production environments must use non-default credentials.
# -----------------------------------------------------------------------------
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=ChangeMe123!

# -----------------------------------------------------------------------------
# Web / Admin Frontend
# These VITE_* variables can later be copied into apps/web/.env.example and
# apps/admin/.env.example once application folders are created.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=小满人生档案馆
VITE_ADMIN_APP_NAME=小满人生档案馆管理后台
VITE_STORAGE_PREVIEW_MODE=signed-url

# -----------------------------------------------------------------------------
# Logging / Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_REQUEST_LOG=true
ENABLE_AUDIT_LOG=true

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# -----------------------------------------------------------------------------
# Seed Demo Data
# -----------------------------------------------------------------------------
SEED_DEMO_PARENT_MOBILE=13800000000
SEED_DEMO_VIEWER_MOBILE=13900000000
