# 小满人生档案馆 - 生产/预发环境变量模板
# 复制为服务器上的 .env.production 或由部署平台 Secret 注入。
# 不要把真实密钥、数据库密码、对象存储密钥、AI 密钥或短信密钥提交到仓库。

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_ENV=production
APP_PORT=3000
APP_BASE_URL=https://api.example.com
ADMIN_BOOTSTRAP_ENABLED=false

# -----------------------------------------------------------------------------
# Database - MySQL 8.x + Prisma
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://<db_user>:<db_password>@<db_host>:3306/<db_name>
MYSQL_ROOT_PASSWORD=<mysql_root_password>
MYSQL_DATABASE=<db_name>
MYSQL_USER=<db_user>
MYSQL_PASSWORD=<db_password>

# -----------------------------------------------------------------------------
# Redis / Queue
# -----------------------------------------------------------------------------
REDIS_HOST=<redis_host>
REDIS_PORT=6379
REDIS_PASSWORD=<redis_password>
REDIS_DB=0

# -----------------------------------------------------------------------------
# Auth - JWT
# 必须使用 32 字节以上随机值，访问令牌和刷新令牌必须不同。
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=<random_64_chars_access_secret>
JWT_REFRESH_SECRET=<random_64_chars_refresh_secret>
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Object Storage
# 可选值：oss / cos / s3 / r2 / minio。生产环境禁止 mock。
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=oss
STORAGE_REGION=<storage_region>
STORAGE_BUCKET=<storage_bucket>
STORAGE_ENDPOINT=https://<storage_endpoint>
STORAGE_ACCESS_KEY=<storage_access_key>
STORAGE_SECRET_KEY=<storage_secret_key>
STORAGE_FORCE_PATH_STYLE=false
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
STORAGE_SIGNED_URL_EXPIRES_IN=600

# -----------------------------------------------------------------------------
# Upload Limits
# -----------------------------------------------------------------------------
UPLOAD_IMAGE_MAX_BYTES=10485760
UPLOAD_VIDEO_MAX_BYTES=104857600
UPLOAD_AUDIO_MAX_BYTES=31457280
UPLOAD_IMAGE_MAX_COUNT_PER_RECORD=9
UPLOAD_VIDEO_MAX_COUNT_PER_RECORD=1
UPLOAD_AUDIO_MAX_COUNT_PER_RECORD=1

# -----------------------------------------------------------------------------
# AI Provider
# 可选值：openai-compatible / openai。生产环境禁止 mock。
# AI_BASE_URL 使用兼容 /chat/completions 的 v1 根地址。
# -----------------------------------------------------------------------------
AI_PROVIDER=openai-compatible
AI_API_KEY=<ai_api_key>
AI_BASE_URL=https://ai.example.com/v1
AI_MODEL=<ai_model>
AI_TIMEOUT_MS=30000
AI_MAX_RETRY_COUNT=2
AI_DAILY_LIMIT_PER_USER=20

# -----------------------------------------------------------------------------
# Map / POI Provider
# 生产默认接入高德地图 POI 搜索；服务端只保存用户选择后的地点文本。
# -----------------------------------------------------------------------------
MAP_PROVIDER=amap
MAP_API_KEY=<map_api_key>
MAP_AMAP_ENDPOINT=https://restapi.amap.com/v3/place/text
MAP_REQUEST_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# SMS Provider
# 当前 App 登录已改为账号密码 + 邀请码，默认不启用短信。若后续重新启用短信能力，再补齐下列变量。
# -----------------------------------------------------------------------------
SMS_ENABLED=false
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_ENDPOINT=https://dysmsapi.aliyuncs.com
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
SMS_DAILY_LIMIT_PER_MOBILE=10
SMS_VERIFY_MAX_ATTEMPTS=5
SMS_CODE_PEPPER=

# -----------------------------------------------------------------------------
# Admin Bootstrap
# 生产默认关闭初始化账号。确需初始化时只在首次部署临时开启，并设置强密码。
# -----------------------------------------------------------------------------
ADMIN_INITIAL_USERNAME=<bootstrap_admin_username>
ADMIN_INITIAL_PASSWORD=<bootstrap_admin_strong_password>

# -----------------------------------------------------------------------------
# Web / Admin Frontend
# Vite 变量在构建 Web/Admin 镜像时注入。
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://api.example.com/api/v1
VITE_APP_NAME=小满人生档案馆
VITE_ADMIN_APP_NAME=小满人生档案馆管理后台
VITE_STORAGE_PREVIEW_MODE=signed-url

# -----------------------------------------------------------------------------
# Logging / Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_REQUEST_LOG=true
ENABLE_AUDIT_LOG=true
LOG_DIR=/var/log/xiaoman

# -----------------------------------------------------------------------------
# CORS
# 多个来源用英文逗号分隔，只填写正式 App/Admin 域名。
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://app.example.com,https://admin.example.com
