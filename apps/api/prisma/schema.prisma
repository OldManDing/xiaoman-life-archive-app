generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum MembershipType {
  free
  family_member
  ai_plus
}

enum AuthType {
  mobile
  wechat
  email
  password
}

enum FamilyMemberRole {
  owner
  editor
  viewer
}

enum ChildGender {
  male
  female
  unknown
}

enum RecordType {
  text
  image
  video
  audio
  mixed
  milestone
}

enum VisibilityScope {
  family
}

enum MediaType {
  image
  video
  audio
  file
}

enum RecordTagSource {
  user
  ai
  system
}

enum ShareTargetType {
  child
  record
  month_report
}

enum AiJobType {
  record_title
  record_summary
  record_tags
  monthly_report
}

enum AiJobStatus {
  pending
  processing
  success
  failed
  cancelled
}

enum RecordAiStatus {
  pending
  success
  failed
  skipped
}

enum ActorType {
  user
  admin
  system
}

enum AdminRole {
  super_admin
  operator
  viewer
}

enum ArchiveExportRequestType {
  all
  media
  text
}

enum ArchiveExportRequestPurpose {
  backup
  adult_handoff
}

enum ArchiveExportRequestStatus {
  submitted
  processing
  completed
  rejected
}

enum SupportTicketStatus {
  submitted
  processing
  resolved
  closed
}

enum SupportTicketPriority {
  normal
  urgent
  child_safety
}

model User {
  id                 BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  userNo             String         @unique(map: "uk_user_no") @map("user_no") @db.VarChar(32)
  nickname           String         @db.VarChar(64)
  avatarUrl          String?        @map("avatar_url") @db.VarChar(512)
  mobile             String?        @db.VarChar(32)
  email              String?        @db.VarChar(128)
  status             Int            @default(1) @db.TinyInt
  membershipType     MembershipType @default(free) @map("membership_type")
  membershipExpireAt DateTime?      @map("membership_expire_at")
  lastLoginAt        DateTime?      @map("last_login_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  authAccounts          UserAuthAccount[]
  ownedFamilies         Family[]           @relation("FamilyOwner")
  familyMemberships     FamilyMember[]     @relation("FamilyMembershipUser")
  invitedFamilyMembers  FamilyMember[]     @relation("FamilyMemberInviter")
  ownedChildren         Child[]            @relation("ChildOwner")
  createdRecords        Record[]           @relation("RecordCreator")
  uploadedMedia         RecordMedia[]      @relation("MediaUploader")
  sentInvites           MemberInvite[]     @relation("InviteSender")
  acceptedInvites       MemberInvite[]     @relation("InviteAccepter")
  acceptedRegistrationInvites RegistrationInvite[] @relation("RegistrationInviteAccepter")
  createdShareLinks     ShareLink[]        @relation("ShareCreator")
  requestedAiJobs       AiJob[]            @relation("AiJobRequester")
  archiveExportRequests ArchiveExportRequest[] @relation("ArchiveExportRequester")
  supportTickets        SupportTicket[]    @relation("SupportTicketReporter")
  sessions              UserSession[]

  @@index([mobile], map: "idx_mobile")
  @@index([email], map: "idx_email")
  @@index([status], map: "idx_status")
  @@map("users")
}

model UserSession {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId           BigInt    @map("user_id") @db.UnsignedBigInt
  refreshTokenHash String    @unique(map: "uk_refresh_token_hash") @map("refresh_token_hash") @db.VarChar(128)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_user_id")
  @@index([expiresAt], map: "idx_expires_at")
  @@map("user_sessions")
}

model SmsVerificationCode {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  mobile     String   @db.VarChar(32)
  scene      String   @db.VarChar(32)
  codeHash   String   @map("code_hash") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  failedAttempts Int  @default(0) @map("failed_attempts")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([mobile, scene], map: "idx_mobile_scene")
  @@index([expiresAt], map: "idx_expires_at")
  @@map("sms_verification_codes")
}

model UserAuthAccount {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId         BigInt    @map("user_id") @db.UnsignedBigInt
  authType       AuthType  @map("auth_type")
  authKey        String    @map("auth_key") @db.VarChar(128)
  credentialHash String?   @map("credential_hash") @db.VarChar(255)
  status         Int       @default(1) @db.TinyInt
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([authType, authKey], map: "uk_auth_type_key")
  @@index([userId], map: "idx_user_id")
  @@map("user_auth_accounts")
}

model Family {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  familyNo    String    @unique(map: "uk_family_no") @map("family_no") @db.VarChar(32)
  ownerUserId BigInt    @map("owner_user_id") @db.UnsignedBigInt
  name        String?   @db.VarChar(64)
  status      Int       @default(1) @db.TinyInt
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  owner        User           @relation("FamilyOwner", fields: [ownerUserId], references: [id])
  members      FamilyMember[]
  children     Child[]
  records      Record[]
  media        RecordMedia[]
  invites      MemberInvite[]
  shareLinks   ShareLink[]
  aiJobs       AiJob[]
  archiveExportRequests ArchiveExportRequest[]

  @@index([ownerUserId], map: "idx_owner_user_id")
  @@map("families")
}

model FamilyMember {
  id            BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  familyId      BigInt           @map("family_id") @db.UnsignedBigInt
  userId        BigInt           @map("user_id") @db.UnsignedBigInt
  role          FamilyMemberRole @default(viewer)
  status        Int              @default(1) @db.TinyInt
  inviterUserId BigInt?          @map("inviter_user_id") @db.UnsignedBigInt
  joinedAt      DateTime?        @map("joined_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  family  Family @relation(fields: [familyId], references: [id])
  user    User   @relation("FamilyMembershipUser", fields: [userId], references: [id])
  inviter User?  @relation("FamilyMemberInviter", fields: [inviterUserId], references: [id])

  @@unique([familyId, userId], map: "uk_family_user")
  @@index([userId], map: "idx_user_id")
  @@index([familyId, role], map: "idx_family_role")
  @@index([status], map: "idx_status")
  @@map("family_members")
}

model Child {
  id          BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  childNo     String      @unique(map: "uk_child_no") @map("child_no") @db.VarChar(32)
  familyId    BigInt      @map("family_id") @db.UnsignedBigInt
  ownerUserId BigInt      @map("owner_user_id") @db.UnsignedBigInt
  name        String      @db.VarChar(64)
  avatarUrl   String?     @map("avatar_url") @db.VarChar(512)
  birthday    DateTime    @db.Date
  gender      ChildGender @default(unknown)
  birthPlace  String?     @map("birth_place") @db.VarChar(128)
  remark      String?     @db.VarChar(255)
  status      Int         @default(1) @db.TinyInt
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  family  Family   @relation(fields: [familyId], references: [id])
  owner   User     @relation("ChildOwner", fields: [ownerUserId], references: [id])
  records Record[]
  media    RecordMedia[]
  archiveExportRequests ArchiveExportRequest[]

  @@index([familyId], map: "idx_family_id")
  @@index([ownerUserId], map: "idx_owner_user_id")
  @@index([status], map: "idx_status")
  @@index([birthday], map: "idx_birthday")
  @@map("children")
}

model Record {
  id               BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  recordNo         String          @unique(map: "uk_record_no") @map("record_no") @db.VarChar(32)
  childId          BigInt          @map("child_id") @db.UnsignedBigInt
  familyId         BigInt          @map("family_id") @db.UnsignedBigInt
  creatorUserId    BigInt          @map("creator_user_id") @db.UnsignedBigInt
  recordType       RecordType      @map("record_type")
  title            String?         @db.VarChar(128)
  contentText      String?         @map("content_text") @db.Text
  eventTime        DateTime        @default(now()) @map("event_time")
  locationText     String?         @map("location_text") @db.VarChar(128)
  visibilityScope  VisibilityScope @default(family) @map("visibility_scope")
  isMilestone      Boolean         @default(false) @map("is_milestone")
  aiGeneratedTitle String?         @map("ai_generated_title") @db.VarChar(128)
  aiSummary        String?         @map("ai_summary") @db.VarChar(512)
  aiStatus         RecordAiStatus? @map("ai_status")
  status           Int             @default(2) @db.TinyInt
  publishedAt      DateTime?       @map("published_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  child     Child        @relation(fields: [childId], references: [id])
  family    Family       @relation(fields: [familyId], references: [id])
  creator   User         @relation("RecordCreator", fields: [creatorUserId], references: [id])
  media     RecordMedia[]
  tags      RecordTag[]
  aiJobs    AiJob[]

  @@index([childId, status, eventTime], map: "idx_child_status_event_time")
  @@index([familyId, status, eventTime], map: "idx_family_status_event_time")
  @@index([creatorUserId], map: "idx_creator_user_id")
  @@index([isMilestone], map: "idx_is_milestone")
  @@map("records")
}

model RecordMedia {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  mediaNo            String    @unique(map: "uk_media_no") @map("media_no") @db.VarChar(32)
  recordId           BigInt?   @map("record_id") @db.UnsignedBigInt
  familyId           BigInt    @map("family_id") @db.UnsignedBigInt
  childId            BigInt?   @map("child_id") @db.UnsignedBigInt
  uploaderUserId     BigInt    @map("uploader_user_id") @db.UnsignedBigInt
  mediaType          MediaType @map("media_type")
  storageProvider    String    @map("storage_provider") @db.VarChar(32)
  bucket             String    @db.VarChar(128)
  objectKey          String    @map("object_key") @db.VarChar(512)
  originalName       String?   @map("original_name") @db.VarChar(255)
  mimeType           String?   @map("mime_type") @db.VarChar(128)
  sizeBytes          BigInt?   @map("size_bytes") @db.UnsignedBigInt
  width              Int?      @db.UnsignedInt
  height             Int?      @db.UnsignedInt
  durationSeconds    Int?      @map("duration_seconds") @db.UnsignedInt
  thumbnailObjectKey String?   @map("thumbnail_object_key") @db.VarChar(512)
  status             Int       @default(1) @db.TinyInt
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  record   Record? @relation(fields: [recordId], references: [id])
  family   Family  @relation(fields: [familyId], references: [id])
  child    Child?  @relation(fields: [childId], references: [id])
  uploader User    @relation("MediaUploader", fields: [uploaderUserId], references: [id])

  @@index([recordId], map: "idx_record_id")
  @@index([familyId], map: "idx_family_id")
  @@index([childId], map: "idx_child_id")
  @@index([uploaderUserId], map: "idx_uploader_user_id")
  @@index([status], map: "idx_status")
  @@map("record_media")
}

model RecordTag {
  id        BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  recordId  BigInt          @map("record_id") @db.UnsignedBigInt
  tagName   String          @map("tag_name") @db.VarChar(32)
  source    RecordTagSource @default(user)
  createdAt DateTime        @default(now()) @map("created_at")

  record Record @relation(fields: [recordId], references: [id])

  @@unique([recordId, tagName, source], map: "uk_record_tag_source")
  @@index([tagName], map: "idx_tag_name")
  @@map("record_tags")
}

model MemberInvite {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  inviteNo       String           @unique(map: "uk_invite_no") @map("invite_no") @db.VarChar(32)
  familyId       BigInt           @map("family_id") @db.UnsignedBigInt
  inviterUserId  BigInt           @map("inviter_user_id") @db.UnsignedBigInt
  inviteeMobile  String?          @map("invitee_mobile") @db.VarChar(32)
  inviteeUserId  BigInt?          @map("invitee_user_id") @db.UnsignedBigInt
  role           FamilyMemberRole @default(viewer)
  tokenHash      String           @unique(map: "uk_token_hash") @map("token_hash") @db.VarChar(128)
  status         Int              @default(1) @db.TinyInt
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  family   Family @relation(fields: [familyId], references: [id])
  inviter  User   @relation("InviteSender", fields: [inviterUserId], references: [id])
  invitee  User?  @relation("InviteAccepter", fields: [inviteeUserId], references: [id])

  @@index([familyId], map: "idx_family_id")
  @@index([status, expiresAt], map: "idx_status_expires_at")
  @@map("member_invites")
}

model ShareLink {
  id            BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  shareNo       String          @unique(map: "uk_share_no") @map("share_no") @db.VarChar(32)
  familyId      BigInt          @map("family_id") @db.UnsignedBigInt
  creatorUserId BigInt          @map("creator_user_id") @db.UnsignedBigInt
  targetType    ShareTargetType @map("target_type")
  targetId      BigInt          @map("target_id") @db.UnsignedBigInt
  tokenHash     String          @unique(map: "uk_token_hash") @map("token_hash") @db.VarChar(128)
  expiresAt     DateTime        @map("expires_at")
  status        Int             @default(1) @db.TinyInt
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  family  Family @relation(fields: [familyId], references: [id])
  creator User   @relation("ShareCreator", fields: [creatorUserId], references: [id])

  @@index([familyId], map: "idx_family_id")
  @@index([targetType, targetId], map: "idx_target")
  @@map("share_links")
}

model AiJob {
  id              BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  jobNo           String      @unique(map: "uk_job_no") @map("job_no") @db.VarChar(32)
  familyId        BigInt      @map("family_id") @db.UnsignedBigInt
  recordId        BigInt?     @map("record_id") @db.UnsignedBigInt
  requesterUserId BigInt      @map("requester_user_id") @db.UnsignedBigInt
  jobType         AiJobType   @map("job_type")
  provider        String?     @db.VarChar(32)
  status          AiJobStatus @default(pending)
  inputSnapshot   Json?       @map("input_snapshot")
  outputJson      Json?       @map("output_json")
  errorMessage    String?     @map("error_message") @db.VarChar(512)
  retryCount      Int         @default(0) @map("retry_count")
  startedAt       DateTime?   @map("started_at")
  finishedAt      DateTime?   @map("finished_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  family    Family  @relation(fields: [familyId], references: [id])
  record    Record? @relation(fields: [recordId], references: [id])
  requester User    @relation("AiJobRequester", fields: [requesterUserId], references: [id])

  @@index([familyId], map: "idx_family_id")
  @@index([recordId], map: "idx_record_id")
  @@index([status], map: "idx_status")
  @@index([jobType], map: "idx_job_type")
  @@map("ai_jobs")
}

model AdminUser {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  username      String    @unique(map: "uk_username") @db.VarChar(64)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  displayName   String    @map("display_name") @db.VarChar(64)
  role          AdminRole
  status        Int       @default(1) @db.TinyInt
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  createdRegistrationInvites RegistrationInvite[] @relation("RegistrationInviteCreator")
  processedArchiveExportRequests ArchiveExportRequest[] @relation("ArchiveExportProcessor")
  assignedSupportTickets SupportTicket[] @relation("SupportTicketAssignee")
  updatedSystemConfigs SystemConfig[] @relation("SystemConfigUpdater")

  @@index([status], map: "idx_status")
  @@map("admin_users")
}

model SystemConfig {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  configKey        String    @unique(map: "uk_system_config_key") @map("config_key") @db.VarChar(64)
  category         String    @db.VarChar(32)
  label            String    @db.VarChar(64)
  value            String    @db.Text
  valueType        String    @map("value_type") @db.VarChar(24)
  description      String    @db.VarChar(255)
  updatedByAdminId BigInt?   @map("updated_by_admin_id") @db.UnsignedBigInt
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  updatedByAdmin AdminUser? @relation("SystemConfigUpdater", fields: [updatedByAdminId], references: [id])

  @@index([category], map: "idx_category")
  @@index([updatedByAdminId], map: "idx_updated_by_admin_id")
  @@map("system_configs")
}

model RegistrationInvite {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  inviteNo         String    @unique(map: "uk_registration_invite_no") @map("invite_no") @db.VarChar(32)
  tokenHash        String    @unique(map: "uk_registration_token_hash") @map("token_hash") @db.VarChar(128)
  inviteeMobile    String?   @map("invitee_mobile") @db.VarChar(32)
  createdByAdminId BigInt    @map("created_by_admin_id") @db.UnsignedBigInt
  acceptedByUserId BigInt?   @map("accepted_by_user_id") @db.UnsignedBigInt
  status           Int       @default(1) @db.TinyInt
  expiresAt        DateTime  @map("expires_at")
  acceptedAt       DateTime? @map("accepted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdByAdmin AdminUser @relation("RegistrationInviteCreator", fields: [createdByAdminId], references: [id])
  acceptedByUser User?     @relation("RegistrationInviteAccepter", fields: [acceptedByUserId], references: [id])

  @@index([status, expiresAt], map: "idx_status_expires_at")
  @@index([createdByAdminId], map: "idx_created_by_admin_id")
  @@index([acceptedByUserId], map: "idx_accepted_by_user_id")
  @@map("registration_invites")
}

model ArchiveExportRequest {
  id                 BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  requestNo          String                     @unique(map: "uk_archive_export_request_no") @map("request_no") @db.VarChar(32)
  userId             BigInt                     @map("user_id") @db.UnsignedBigInt
  familyId           BigInt                     @map("family_id") @db.UnsignedBigInt
  childId            BigInt                     @map("child_id") @db.UnsignedBigInt
  exportType         ArchiveExportRequestType   @map("export_type")
  purpose            ArchiveExportRequestPurpose
  status             ArchiveExportRequestStatus @default(submitted)
  contact            String?                    @db.VarChar(128)
  note               String?                    @db.VarChar(500)
  recordCount        Int                        @default(0) @map("record_count")
  milestoneCount     Int                        @default(0) @map("milestone_count")
  mediaCount         Int                        @default(0) @map("media_count")
  firstRecordTime    DateTime?                  @map("first_record_time")
  latestRecordTime   DateTime?                  @map("latest_record_time")
  processedByAdminId BigInt?                    @map("processed_by_admin_id") @db.UnsignedBigInt
  processedAt        DateTime?                  @map("processed_at")
  processNote        String?                    @map("process_note") @db.VarChar(500)
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  user             User       @relation("ArchiveExportRequester", fields: [userId], references: [id])
  family           Family     @relation(fields: [familyId], references: [id])
  child            Child      @relation(fields: [childId], references: [id])
  processedByAdmin AdminUser? @relation("ArchiveExportProcessor", fields: [processedByAdminId], references: [id])

  @@index([userId], map: "idx_user_id")
  @@index([familyId], map: "idx_family_id")
  @@index([childId], map: "idx_child_id")
  @@index([purpose, status, createdAt], map: "idx_purpose_status_created_at")
  @@index([status, createdAt], map: "idx_status_created_at")
  @@map("archive_export_requests")
}

model SupportTicket {
  id              BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  ticketNo        String                @unique(map: "uk_support_ticket_no") @map("ticket_no") @db.VarChar(32)
  userId          BigInt                @map("user_id") @db.UnsignedBigInt
  category        String                @db.VarChar(64)
  topic           String?               @db.VarChar(64)
  content         String                @db.Text
  contact         String?               @db.VarChar(128)
  status          SupportTicketStatus   @default(submitted)
  priority        SupportTicketPriority @default(normal)
  assignedAdminId BigInt?               @map("assigned_admin_id") @db.UnsignedBigInt
  handledAt       DateTime?             @map("handled_at")
  handleNote      String?               @map("handle_note") @db.VarChar(500)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  user          User       @relation("SupportTicketReporter", fields: [userId], references: [id])
  assignedAdmin AdminUser? @relation("SupportTicketAssignee", fields: [assignedAdminId], references: [id])

  @@index([userId], map: "idx_user_id")
  @@index([assignedAdminId], map: "idx_assigned_admin_id")
  @@index([status, createdAt], map: "idx_status_created_at")
  @@index([priority, status, createdAt], map: "idx_priority_status_created_at")
  @@map("support_tickets")
}

model AuditLog {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  actorType  ActorType @map("actor_type")
  actorId    BigInt    @map("actor_id") @db.UnsignedBigInt
  action     String    @db.VarChar(64)
  targetType String    @map("target_type") @db.VarChar(64)
  targetId   BigInt?   @map("target_id") @db.UnsignedBigInt
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([actorType, actorId], map: "idx_actor")
  @@index([targetType, targetId], map: "idx_target")
  @@index([action], map: "idx_action")
  @@index([createdAt], map: "idx_created_at")
  @@map("audit_logs")
}
