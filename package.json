{
  "name": "xiaoman-archive-app",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:admin": "npm run dev -w apps/admin",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:admin": "npm run build -w apps/admin",
    "build:mobile": "npm run build -w apps/mobile",
    "start:api": "npm run start -w apps/api",
    "regression:baseline": "npm run prisma:generate && npm run typecheck:api && npm run test:api && npm run smoke:test:api && npm run typecheck:web && npm run test:web && npm run typecheck:admin && npm run test:admin && npm run lint -w apps/admin",
    "typecheck:api": "npm run typecheck -w apps/api",
    "typecheck:web": "npm run typecheck -w apps/web",
    "typecheck:admin": "npm run typecheck -w apps/admin",
    "test:api": "npm run test -w apps/api",
    "test:web": "npm run test -w apps/web",
    "test:admin": "npm run test -w apps/admin",
    "test:e2e": "node scripts/e2e-prepare.cjs && playwright test",
    "test:e2e:headed": "node scripts/e2e-prepare.cjs && playwright test --headed",
    "coverage:baseline": "npm run test:coverage -w apps/api && npm run test:coverage -w apps/web && npm run test:coverage -w apps/admin",
    "verify:production-template": "node scripts/verify-production-config.cjs --template .env.example",
    "verify:production-env": "node scripts/verify-production-config.cjs --env .env.production",
    "verify:security-baseline": "node scripts/verify-security-baseline.cjs",
    "verify:live-readiness": "node scripts/verify-live-readiness.cjs",
    "sync:mobile": "npm run sync -w apps/mobile",
    "mobile:add:android": "npm run add:android -w apps/mobile",
    "mobile:add:ios": "npm run add:ios -w apps/mobile",
    "smoke:test:api": "npm run smoke:test -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:dbpush": "npm run prisma:dbpush -w apps/api",
    "prisma:seed": "npm run prisma:seed -w apps/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.1.19"
  }
}
